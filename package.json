{
  "name": "isometry",
  "version": "1.0.0",
  "description": "Isometry v5 — SuperGrid spatial knowledge visualization",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:native": "vite build --config vite.config.native.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:harness": "vitest --run tests/harness",
    "test:seams": "vitest --run --passWithNoTests tests/seams",
    "lint": "biome check .",
    "lint:css": "stylelint 'src/styles/**/*.css'",
    "fix": "biome check --write .",
    "e2e": "npx playwright test",
    "e2e:headed": "npx playwright test --headed",
    "e2e:debug": "npx playwright test --debug",
    "e2e:report": "npx playwright show-report e2e/report",
    "analyze": "vite build --config vite.config.analyze.ts",
    "bench:budgets": "vitest run tests/profiling/budget.test.ts tests/profiling/budget-render.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "d3": "^7.9.0",
    "dompurify": "^3.3.2",
    "driver.js": "^1.4.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-types": "^0.24.8",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.4",
    "papaparse": "^5.5.3",
    "sql.js": "^1.14.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/sql.js": "^1.4.9",
    "@types/tmp": "^0.2.6",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/web-worker": "^4.0.18",
    "better-sqlite3": "^12.8.0",
    "buffer": "^6.0.3",
    "jsdom": "^28.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tmp": "^0.2.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  }
}
